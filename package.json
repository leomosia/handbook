{
  "name": "leomosia-handbook",
  "private": true,
  "version": "0.1.0",
  "description": "The Leo Mosia Handbook source site.",
  "repository": {
    "type": "git",
    "url": "git+ssh://git@github.com/leomosia/handbook.git"
  },
  "scripts": {
    "clean": "bash scripts/cleanup.sh",
    "predev": "npm run clean",
    "prebuild": "npm run clean",
    "meta": "node scripts/generate-handbook-meta.mjs",
    "dev": "npm run meta && hugo server --bind 0.0.0.0 --port ${HUGO_PORT:-1313} --appendPort=false --renderToMemory --baseURL ${HANDBOOK_BASE_URL:-http://localhost:1313}",
    "build": "npm run meta && hugo --gc --minify",
    "lint:md": "markdownlint-cli2 \"**/*.md\" \"!public/**\" \"!resources/**\" \"!node_modules/**\"",
    "check": "npm run lint:md && npm run build"
  },
  "devDependencies": {
    "@fortawesome/fontawesome-free": "^6.7.2",
    "autoprefixer": "^10.4.21",
    "bootstrap": "^5.3.8",
    "hugo-extended": "^0.158.0",
    "markdownlint-cli2": "^0.18.1",
    "postcss": "^8.5.6",
    "postcss-cli": "^11.0.1"
  }
}
